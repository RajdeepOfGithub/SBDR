# ========== SECRETS ==========
.env

# ========== CLAUDE CODE (internal session data) ==========
.claude/

# ========== DATA FILES (NEVER PUSH TO GITHUB) ==========
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/synthetic/*
!data/synthetic/.gitkeep
*.csv
*.xls
*.xlsx
*.parquet
*.h5
*.hdf5

# ========== MODEL WEIGHTS (too large / not for version control) ==========
*.pt
*.pth
*.pkl
*.joblib
models/saved/
# Manifests, plots, indices, and trained XGBoost model ARE pushed (see models/ section)

# ========== PYTHON ==========
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/

# ========== JUPYTER ==========
.ipynb_checkpoints/

# ========== macOS ==========
.DS_Store
.AppleDouble
.LSOverride

# ========== IDE ==========
.vscode/
.idea/
*.swp
*.swo

# ========== STREAMLIT ==========
.streamlit/secrets.toml

# ========== JSON — block raw data only, allow model manifests & weights ==========
# Block large raw data JSON files
data/**/*.json
# Everything under models/ is allowed (manifests, xgboost model, etc.)
# .obsidian config JSON is allowed (team vault sync)

# ========== OBSIDIAN ==========
# We KEEP .obsidian/ tracked so vault config syncs across team
# But ignore workspace files (personal to each machine)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
